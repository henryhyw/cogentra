{
  "name": "concentra",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "uv run --project apps/api uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "pnpm --dir apps/web build",
    "lint": "pnpm --dir apps/web lint",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "uv run --project apps/api pytest",
    "test:web": "pnpm --dir apps/web test",
    "test:e2e": "pnpm --dir apps/web test:e2e",
    "seed": "uv run --project apps/api python -m app.scripts.seed_demo",
    "reset-demo": "uv run --project apps/api python -m app.scripts.seed_demo --reset"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
